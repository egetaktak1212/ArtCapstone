#:kivy 2.3.0
#:import get_color_from_hex kivy.utils.get_color_from_hex

<ImgButton@ButtonBehavior+Image>:
    allow_stretch: False
    keep_ratio: True


<MainMenu>:
    FloatLayout:
        canvas.before:
            Color:
                rgba: get_color_from_hex("#605a3f")
            Rectangle:
                pos: self.pos
                size: self.size

        AnchorLayout:
            anchor_x: "center"
            anchor_y: "top"

            BoxLayout:
                size_hint_x: None
                width: root.width * 0.7
                orientation: "vertical"

                canvas.before:
                    Color:
                        rgba: get_color_from_hex("#DAD4AF")
                    Rectangle:
                        pos: self.pos
                        size: self.size
                BoxLayout:
                    size_hint_y: None
                    height: root.height*0.22

                    canvas.before:
                        Color:
                            rgba: get_color_from_hex("#E1DFCE")
                        Rectangle:
                            pos: self.pos
                            size: self.size

                    FloatLayout:

                        Image:
                            source: "assets/homepage/JectorLogo.png"

                            size_hint: None, None
                            height: self.parent.height * 0.9
                            width: self.parent.width * 0.7

                            pos_hint: {"center_x": 0.4, "center_y": 0.5}
                            keep_ratio: True

                        Button:
                            background_normal: "assets/homepage/buttons/powerButton.png"
                            background_down: "assets/homepage/buttons/powerButton.png"

                            size_hint: None, None
                            height: self.parent.height * 0.85
                            width: self.height * (500 / 776) 
                            
                            

                            pos_hint: {"center_x": 0.9, "center_y": 0.5}
                            
                            on_press: app.stop()
                
                BoxLayout:
                    padding: dp(20)
                    spacing: dp(7)

                    BoxLayout:
                        orientation: "vertical"
                        size_hint_x: 0.4
                        spacing: dp(5)
                        size_hint_y: None
                        height: self.minimum_height
                        pos_hint: {"top": 0.9}

                        ImgButton:
                            source: "./assets/homepage/buttons/opencamera.png"
                            on_press: root.manager.current = 'cameraWindow'
                            size_hint_y: None
                            height: self.width * (415 / 927)

                        ImgButton:
                            source: "./assets/homepage/buttons/uploadfile.png"
                            on_press: root.file_picker()
                            size_hint_y: None
                            height: self.width * (415 / 924)

                        ImgButton:
                            source: "./assets/homepage/buttons/editfeatures.png"
                            on_press: root.open_editor_again()
                            size_hint_y: None
                            height: self.width * (416 / 923)
                            

                    AnchorLayout:
                        anchor_x: "center"
                        anchor_y: "center"

                        BoxLayout:
                            size_hint: None, None
                            size: min(self.parent.width, self.parent.height) * 0.8, min(self.parent.width, self.parent.height) * 0.8

                            canvas.before:
                                Color:
                                    rgba: get_color_from_hex("#8C9372")
                                Rectangle:
                                    pos: self.pos
                                    size: self.size

                            BoxLayout:
                                id: previewContainer
                                size_hint: 1, 1

                                
                
                BoxLayout:
                    size_hint_y: 0.2
                    padding: dp(10)

                    canvas.before:
                        Color:
                            rgba: get_color_from_hex("#C8C29B")
                        Rectangle:
                            pos: self.pos
                            size: self.size

                    AnchorLayout:
                        anchor_x: "left"
                        anchor_y: "center"


                        Image:
                            source: "assets/homepage/diskdrive.png"

                            size_hint: None, None
                            width: self.parent.parent.width * 0.8

                            keep_ratio: True
                            allow_stretch: True
                    

                    

<CamWindow>:
    FloatLayout:
        Image:
            source: "./assets/campage/page.png"
            allow_stretch: True
            keep_ratio: True
            size_hint: 1,1
            size: self.parent.size
            pos: self.parent.pos
        RelativeLayout:
            id: container
            size_hint: None, None
            size: self.parent.size
            pos_hint: {"center_x": 0.5, "center_y": 0.5}
            CamWidget:
                id: camwidget
                size_hint: (1,1)
                
                pos_hint: {"center_x": 0.5, "center_y": 0.48}

            Button:
                background_normal: "./assets/campage/buttons/big.png"
                background_down: "./assets/campage/buttons/big.png"

                size_hint: 0.05, None
                height: self.width

                border: 0, 0, 0, 0
                pos_hint: {"x": 0.32, "y": 0.14}

                on_press: camwidget.scale_change(True)
            Button:
                background_normal: "./assets/campage/buttons/small.png"
                background_down: "./assets/campage/buttons/small.png"

                size_hint: 0.05, None
                height: self.width

                border: 0, 0, 0, 0
                pos_hint: {"x": 0.32, "y": 0.06}
                on_press: camwidget.scale_change(False)
            Button:
                background_normal: "./assets/campage/buttons/up.png"
                background_down: "./assets/campage/buttons/up.png"

                size_hint: 0.05, None
                height: self.width

                border: 0, 0, 0, 0
                pos_hint: {"x": 0.14, "y": 0.15}
                on_press: camwidget.pos_change((0,-camwidget.move_button_amount))
            Button:
                background_normal: "./assets/campage/buttons/left.png"
                background_down: "./assets/campage/buttons/left.png"

                size_hint: 0.05, None
                height: self.width

                border: 0, 0, 0, 0
                pos_hint: {"x": 0.08, "y": 0.10}
                on_press: camwidget.pos_change((-camwidget.move_button_amount,0))
            Button:
                background_normal: "./assets/campage/buttons/right.png"
                background_down: "./assets/campage/buttons/right.png"

                size_hint: 0.05, None
                height: self.width 

                border: 0, 0, 0, 0
                pos_hint: {"x": 0.20, "y": 0.10}
                on_press: camwidget.pos_change((camwidget.move_button_amount,0))
            Button:
                background_normal: "./assets/campage/buttons/down.png"
                background_down: "./assets/campage/buttons/down.png"

                size_hint: 0.05, None
                height: self.width 

                border: 0, 0, 0, 0
                pos_hint: {"x": 0.14, "y": 0.05}
                on_press: camwidget.pos_change((0,camwidget.move_button_amount))
            Button:
                background_normal: "./assets/campage/buttons/clock.png"
                background_down: "./assets/campage/buttons/clock.png"

                size_hint: 0.05, None
                height: self.width

                border: 0, 0, 0, 0
                pos_hint: {"x": 0.48, "y": 0.10}
                on_press: camwidget.angle_change(True)
            Button:
                background_normal: "./assets/campage/buttons/counter.png"
                background_down: "./assets/campage/buttons/counter.png"

                size_hint: 0.05, None
                height: self.width

                border: 0, 0, 0, 0
                pos_hint: {"x": 0.58, "y": 0.10}
                on_press: camwidget.angle_change(False)
            Button:
                background_normal: "./assets/campage/buttons/alphaplus.png"
                background_down: "./assets/campage/buttons/alphaplus.png"

                size_hint: 0.05, None
                height: self.width 

                border: 0, 0, 0, 0
                pos_hint: {"x": 0.84, "y": 0.1}
                on_press: camwidget.alpha_change(True)
            Button:
                background_normal: "./assets/campage/buttons/alphaminus.png"
                background_down: "./assets/campage/buttons/alphaminus.png"

                size_hint: 0.05, None
                height: self.width

                border: 0, 0, 0, 0
                pos_hint: {"x": 0.74, "y": 0.10}
                on_press: camwidget.alpha_change(False)
            Button:
                background_normal: "./assets/campage/buttons/cam.png"
                background_down: "./assets/campage/buttons/cam.png"

                size_hint: 0.09, None
                height: self.width

                border: 0, 0, 0, 0
                pos_hint: {"x": 0.80, "y": 0.44}
                on_press: camwidget.pause()
            Button:
                background_normal: "./assets/campage/buttons/menu.png"
                background_down: "./assets/campage/buttons/menu.png"

                size_hint: 0.20, None
                height: self.width * (51 / 201) 

                border: 0, 0, 0, 0
                pos_hint: {"x": 0.5 - self.width/2/self.parent.width, "y": 0.745}
                on_press: root.manager.current = 'mainMenu'
    