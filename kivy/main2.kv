#:kivy 2.3.0
#:import get_color_from_hex kivy.utils.get_color_from_hex

<ImgButton@ButtonBehavior+Image>:
    allow_stretch: False
    keep_ratio: True


<MainMenu>:
    FloatLayout:
        canvas.before:
            Color:
                rgba: get_color_from_hex("#605a3f")
            Rectangle:
                pos: self.pos
                size: self.size

        AnchorLayout:
            anchor_x: "center"
            anchor_y: "top"

            BoxLayout:
                size_hint_x: None
                width: root.width * 0.7
                orientation: "vertical"

                canvas.before:
                    Color:
                        rgba: get_color_from_hex("#DAD4AF")
                    Rectangle:
                        pos: self.pos
                        size: self.size
                BoxLayout:
                    size_hint_y: None
                    height: root.height*0.22

                    canvas.before:
                        Color:
                            rgba: get_color_from_hex("#E1DFCE")
                        Rectangle:
                            pos: self.pos
                            size: self.size

                    FloatLayout:

                        Image:
                            source: "assets/homepage/JectorLogo.png"

                            size_hint: None, None
                            height: self.parent.height * 0.9
                            width: self.parent.width * 0.7

                            pos_hint: {"center_x": 0.4, "center_y": 0.5}
                            keep_ratio: True

                        Button:
                            background_normal: "assets/homepage/buttons/powerButton.png"
                            background_down: "assets/homepage/buttons/powerButton.png"

                            size_hint: None, None
                            height: self.parent.height * 0.85
                            width: self.height * (500 / 776) 
                            
                            

                            pos_hint: {"center_x": 0.9, "center_y": 0.5}
                            
                            on_press: app.stop()
                
                BoxLayout:
                    padding: dp(20)
                    spacing: dp(7)

                    BoxLayout:
                        orientation: "vertical"
                        size_hint_x: 0.4
                        spacing: dp(5)
                        size_hint_y: None
                        height: self.minimum_height
                        pos_hint: {"top": 0.9}

                        ImgButton:
                            source: "./assets/homepage/buttons/opencamera.png"
                            on_press: root.cam_opener()
                            size_hint_y: None
                            height: self.width * (415 / 927)

                        ImgButton:
                            source: "./assets/homepage/buttons/uploadfile.png"
                            on_press: root.file_picker()
                            size_hint_y: None
                            height: self.width * (415 / 924)

                        ImgButton:
                            source: "./assets/homepage/buttons/editfeatures.png"
                            on_press: root.open_editor_again()
                            size_hint_y: None
                            height: self.width * (416 / 923)
                            

                    AnchorLayout:
                        anchor_x: "center"
                        anchor_y: "center"

                        BoxLayout:
                            size_hint: None, None
                            size: min(self.parent.width, self.parent.height) * 0.8, min(self.parent.width, self.parent.height) * 0.8

                            canvas.before:
                                Color:
                                    rgba: get_color_from_hex("#8C9372")
                                Rectangle:
                                    pos: self.pos
                                    size: self.size

                            BoxLayout:
                                id: previewContainer
                                size_hint: 1, 1

                                
                
                AnchorLayout:
                    size_hint_y: 0.25
                    anchor_x: "left"
                    anchor_y: "center"

                    canvas.before:
                        Color:
                            rgba: get_color_from_hex("#C8C29B")
                        Rectangle:
                            pos: self.pos
                            size: self.size

                    # Image:
                    #     source: "assets/homepage/diskdrive.png"

                    #     size_hint: None, None
                    #     width: self.parent.parent.width * 0.8

                    #     keep_ratio: True
                    #     allow_stretch: True
                    

                    

<CamWindow>:
    BoxLayout:
        orientation: "horizontal"

        Widget:
            size_hint_x: 0.15

            canvas.before:
                Color:
                    rgba: get_color_from_hex("#605a3f")
                Rectangle:
                    pos: self.pos
                    size: self.size
        
        BoxLayout:
            orientation: "vertical"
            size_hint_x: 0.7

            #head
            BoxLayout:
                size_hint_y: None
                height: root.height*0.22

                canvas.before:
                    Color:
                        rgba: get_color_from_hex("#E1DFCE")
                    Rectangle:
                        pos: self.pos
                        size: self.size

                FloatLayout:

                    Image:
                        source: "assets/homepage/JectorLogo.png"

                        size_hint: None, None
                        height: self.parent.height * 0.9
                        width: self.parent.width * 0.7

                        pos_hint: {"center_x": 0.4, "center_y": 0.5}
                        keep_ratio: True

                    Button:
                        background_normal: "assets/homepage/buttons/powerButton.png"
                        background_down: "assets/homepage/buttons/powerButton.png"

                        size_hint: None, None
                        height: self.parent.height * 0.85
                        width: self.height * (500 / 776) 
                        
                        

                        pos_hint: {"center_x": 0.9, "center_y": 0.5}
                        
                        on_press: app.stop()

            #shit
            BoxLayout:
                BoxLayout:
                    orientation: "vertical"
                    size_hint_x: 0.35
                    padding: dp(10)
                    spacing: dp(10)

                    canvas.before:
                        Color:
                            rgba: get_color_from_hex("#DAD4AF")
                        Rectangle:
                            pos: self.pos
                            size: self.size
                    BoxLayout:
                        spacing: dp(10)
                        size_hint_y: None
                        height: dp(60)
                        
                        Widget:
                        ImgButton:
                            source: "./assets/campage/buttons/up.png"
                            on_press: camwidget.pos_change((0, -camwidget.move_button_amount))
                            height: dp(40)   
                        Widget:
                    BoxLayout:
                        spacing: dp(10)
                        size_hint_y: None
                        height: dp(60)

                        ImgButton:
                            source: "./assets/campage/buttons/left.png"
                            height: dp(40)
                            on_press: camwidget.pos_change((-camwidget.move_button_amount, 0))
                        ImgButton:
                            source: "./assets/campage/buttons/down.png"
                            height: dp(40)
                            on_press: camwidget.pos_change((0, camwidget.move_button_amount))
                        ImgButton:
                            source: "./assets/campage/buttons/right.png"
                            height: dp(40)
                            on_press: camwidget.pos_change((camwidget.move_button_amount, 0))

                    BoxLayout:
                        spacing: dp(5)
                        size_hint_y: None
                        height: dp(60)

                        ImgButton:
                            source: "./assets/campage/buttons/big.png"
                            on_press: camwidget.scale_change(True)
                            height: dp(40)

                        ImgButton:
                            source: "./assets/campage/buttons/small.png"
                            on_press: camwidget.scale_change(False)
                            height: dp(40)

                    BoxLayout:
                        spacing: dp(5)
                        size_hint_y: None
                        height: dp(60)

                        ImgButton:
                            source: "./assets/campage/buttons/clock.png"
                            on_press: camwidget.angle_change(True)
                            height: dp(40)

                        ImgButton:
                            source: "./assets/campage/buttons/counter.png"
                            on_press: camwidget.angle_change(False)
                            height: dp(40)

                    BoxLayout:
                        spacing: dp(5)
                        size_hint_y: None
                        height: dp(60)

                        ImgButton:
                            source: "./assets/campage/buttons/alphaplus.png"
                            on_press: camwidget.alpha_change(True)
                            height: dp(40)

                        ImgButton:
                            source: "./assets/campage/buttons/alphaminus.png"
                            on_press: camwidget.alpha_change(False)
                            height: dp(40)
                    
                    BoxLayout:
                        spacing: dp(5)
                        size_hint_y: None
                        height: dp(60)

                        ImgToggleButton:
                            source_off: "./assets/campage/buttons/refoff.png"
                            source_on: "./assets/campage/buttons/refon.png"
                            source: self.source_on
                            on_press: camwidget.hideShit(0, self)

                        ImgToggleButton:
                            source_off: "./assets/campage/buttons/guideoff.png"
                            source_on: "./assets/campage/buttons/guideon.png"
                            source: self.source_on
                            on_press: camwidget.hideShit(1, self)

                        ImgToggleButton:
                            source_off: "./assets/campage/buttons/sketchoff.png"
                            source_on: "./assets/campage/buttons/sketchon.png"
                            source: self.source_on
                            on_press: camwidget.hideShit(2, self)
                    
                    BoxLayout:
                        spacing: dp(5)
                        size_hint_y: None
                        height: dp(60)

                        ImgButton:
                            source: "./assets/campage/buttons/menu.png"
                            on_press: root.manager.current = 'mainMenu'
                            height: dp(40)

                    Widget:

                AnchorLayout:
                    anchor_x: "center"
                    anchor_y: "center"
                    canvas.before:
                        Color:
                            rgba: get_color_from_hex("#DAD4AF")
                        Rectangle:
                            pos: self.pos
                            size: self.size
                    BoxLayout:
                        size_hint: None, None
                        size: self.parent.width * 0.75, self.parent.height * 0.75

                        canvas.before:
                            Color:
                                rgba: get_color_from_hex("#485338")
                            Rectangle:
                                pos: self.pos
                                size: self.size

                        CamWidget:
                            id: camwidget
        Widget:
            size_hint_x: 0.15

            canvas.before:
                Color:
                    rgba: get_color_from_hex("#605a3f")
                Rectangle:
                    pos: self.pos
                    size: self.size        

